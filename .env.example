# connex database pool configuration
# Copy the variables you need into your service .env

# Maximum open connections (required if you want to override default)
DB_POOL_MAX_OPEN=50

# Maximum idle connections (0 is valid)
DB_POOL_MAX_IDLE=10

# Maximum connection lifetime in seconds
DB_POOL_CONN_MAX_LIFETIME_SEC=3600

# Maximum idle connection time in seconds
DB_POOL_CONN_MAX_IDLE_TIME_SEC=600

# Optional observability metadata
DB_POOL_SOURCE=env
DB_POOL_VERSION=2026-04-20
