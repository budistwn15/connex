# Example for multiple DB connections in one service.
# Each connection has its own pool namespace via custom prefix.

# Main DB
DB_POOL_MAX_OPEN=50
DB_POOL_MAX_IDLE=10
DB_POOL_CONN_MAX_LIFETIME_SEC=3600
DB_POOL_CONN_MAX_IDLE_TIME_SEC=600
DB_POOL_SOURCE=env-main
DB_POOL_VERSION=2026-04-20

# Read replica DB
READ_DB_POOL_MAX_OPEN=80
READ_DB_POOL_MAX_IDLE=20
READ_DB_POOL_CONN_MAX_LIFETIME_SEC=1800
READ_DB_POOL_CONN_MAX_IDLE_TIME_SEC=300
READ_DB_POOL_SOURCE=env-read-replica
READ_DB_POOL_VERSION=2026-04-20

# Analytics DB
ANALYTICS_DB_POOL_MAX_OPEN=30
ANALYTICS_DB_POOL_MAX_IDLE=5
ANALYTICS_DB_POOL_CONN_MAX_LIFETIME_SEC=1200
ANALYTICS_DB_POOL_CONN_MAX_IDLE_TIME_SEC=300
ANALYTICS_DB_POOL_SOURCE=env-analytics
ANALYTICS_DB_POOL_VERSION=2026-04-20
